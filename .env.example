# Flask Configuration
FLASK_SECRET_KEY=your_secret_key_here_change_this_in_production
FLASK_ENV=development

# Database Configuration
DATABASE_URI=sqlite:///safety_app.db
# For PostgreSQL: DATABASE_URI=postgresql://username:password@localhost/safety_app

# Email Configuration (Gmail SMTP)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here

# You'll need to create an App Password for Gmail:
# 1. Go to https://myaccount.google.com/
# 2. Navigate to Security
# 3. Enable 2-Step Verification
# 4. Create App Password for "Mail" and "Windows Computer"
# 5. Copy the 16-character password and paste here
